			},
			{
				"view": "hyperGit.branches",
				"contents": "No Git repository or branches detected.\n[New Branch…](command:hyperGit.branchCreate)"
			},
			{
				"view": "hyperGit.stash",
				"contents": "No stashes yet.\n[Stash Current Changes](command:hyperGit.stashCreate)"
			},
			{
				"view": "hyperGit.shelf",
